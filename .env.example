# Kopyalayın: `.env` olarak kaydedin (Vite sadece `VITE_` ile başlayanları derlemeye dahil eder).

# --- Open Graph (WhatsApp / Facebook önizleme) — index.html içinde mutlak URL üretir ---
# Örnek: https://www.lamosprimevillas.com  (sonda / olmadan)
# Vercel’de Production için Environment Variable olarak da tanımlayın; yoksa varsayılan bu domain kullanılır.
VITE_SITE_ORIGIN=https://www.lamosprimevillas.com

# --- Mimari Vizyon slaytı (ArchitectureSlide) ---
# YouTube: Videoyu yükleyin → Paylaş → Yerleştir (Embed) → iframe içindeki `src="..."` URL’sini buraya yapıştırın.
# Örnek: https://www.youtube-nocookie.com/embed/VIDEO_ID
#
# Gizlilik:
# - Liste dışı (Unlisted): Arama sonuçlarında çıkmaz; sadece linki bilenler açar. Sitenizde embed genelde çalışır.
# - Herkese açık (Public): Aramada da görünebilir.
# - Özel (Private): Başkaları için embed çoğu zaman çalışmaz; yatırımcı slaytı için uygun değildir.
#
# `public/` klasörüne video koymanız gerekmez; YouTube embed URL’si yeterlidir.
# MP4 kullanacaksanız dosyayı `public/` altına koyup `videoSrc="/dosya.mp4"` ile PremiumVideoFrame’e verirsiniz (kodda).
VITE_ARCHITECTURE_VIDEO_EMBED=https://www.youtube-nocookie.com/embed/VK36kgX0XXg

# --- Referans villası (ReferenceProjectSection) ---
VITE_REFERENCE_VIDEO_EMBED=

# --- Proje galerisi — carousel’deki video slaytı (referanstan ayrı) ---
VITE_GALLERY_VIDEO_EMBED=
